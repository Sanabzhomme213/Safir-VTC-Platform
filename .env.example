# ──────────────────────────────────────────────────────────────
# Safir VTC Platform — Variables d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs.
# ──────────────────────────────────────────────────────────────

# Supabase — obligatoire pour la persistance des données
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# OpenAI — pour l'assistant IA (optionnel, configurable aussi depuis les Paramètres)
VITE_OPENAI_KEY=sk-...

# RapidAPI / AviationStack — pour le suivi des vols (optionnel)
VITE_AVIATIONSTACK_KEY=

# Mode démo développeur — affiche des données fictives sans Supabase (ne pas activer en prod)
# VITE_DEV_DEMO=true

# ──────────────────────────────────────────────────────────────
# Secrets Supabase Edge Functions (à configurer dans le dashboard Supabase)
# Ces clés ne sont PAS dans ce fichier — elles vont dans :
# Supabase → Projet → Edge Functions → Secrets
# ──────────────────────────────────────────────────────────────
# SUMUP_API_KEY          — clé API SumUp (me.sumup.com → Développeur)
# SUMUP_MERCHANT_CODE    — code marchand SumUp
# RESEND_API_KEY         — clé API Resend (resend.com) pour l'envoi d'emails
# VONAGE_API_KEY         — clé API Vonage pour les SMS
# VONAGE_API_SECRET      — secret Vonage
# ANTHROPIC_API_KEY      — pour l'IA via Edge Function (optionnel)
